# GRUB boot loader configuration

GRUB_DEFAULT=0
GRUB_TIMEOUT=0
GRUB_TIMEOUT_STYLE=hidden
GRUB_DISTRIBUTOR="Arch"
GRUB_CMDLINE_LINUX_DEFAULT="quiet loglevel=3 splash nvidia_drm.modeset=1 nvidia_drm.fbdev=1 nvidia.NVreg_UsePageAttributeTable=1 nowatchdog mitigations=off nvme_core.default_ps_max_latency_us=0"

GRUB_CMDLINE_LINUX=""

# Preload both GPT and MBR modules
GRUB_PRELOAD_MODULES="part_gpt part_msdos"

GRUB_SAVEDEFAULT=false
GRUB_DISABLE_RECOVERY=true

# Disable submenu
GRUB_DISABLE_SUBMENU=y

# Disable os prober
GRUB_DISABLE_OS_PROBER=true

# Use basic console
GRUB_TERMINAL_INPUT=console
GRUB_TERMINAL_OUTPUT=console
GRUB_GFXMODE=auto
