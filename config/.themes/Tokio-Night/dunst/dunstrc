[global]
    frame_color = "#7aa2f7"
    separator_color = "#24283b"
    font = "JetBrainsMono Nerd Font 10"

[urgency_low]
    background = "#1a1b26"
    foreground = "#a9b1d6"

[urgency_normal]
    background = "#1a1b26"
    foreground = "#a9b1d6"
    timeout = 10

[urgency_critical]
    background = "#1a1b26"
    foreground = "#f7768e"
    frame_color = "#f7768e"
